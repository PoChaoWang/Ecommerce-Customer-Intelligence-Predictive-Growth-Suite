[sqlfluff]
dialect = bigquery
templater = dbt
runaway_check_limit = 10
max_line_length = 120
exclude_rules = layout.indent, references.qualification, structure.using, ambiguous.order_by_limit

[sqlfluff:templater:dbt]
project_dir = ./ecommerce_dbt
profiles_dir = ./ecommerce_dbt

[sqlfluff:indentation]
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper
